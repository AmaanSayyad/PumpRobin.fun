# Admin dashboard (server-only — never expose as NEXT_PUBLIC_)
ADMIN_PASSWORD=change-me-strong-password
ADMIN_SESSION_SECRET=change-me-long-random-string

# WalletConnect (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id

# Footer / community Telegram (e.g. https://t.me/yourchannel)
NEXT_PUBLIC_TELEGRAM_URL=

# After deploying contracts to Robinhood Chain
NEXT_PUBLIC_FACTORY_ADDRESS=0xDe460c58298411517Db8d5d43Ca79E478C4D009F

# Uniswap Trading API (server-only — https://developers.uniswap.org dashboard)
# Used for post-graduation swaps on Robinhood (Universal Router 2.1.1)
UNISWAP_API_KEY=

# Deployer / auto-launch wallet (server-only — never NEXT_PUBLIC_)
PRIVATE_KEY=
FACTORY_PRIVATE_KEY=
CRON_SECRET=your_cron_secret

# Hardhat / Foundry RPC
RH_RPC_URL=https://rpc.mainnet.chain.robinhood.com
RH_TESTNET_RPC_URL=https://rpc.testnet.chain.robinhood.com

# Supabase — token/trade registry (survives refresh & deploy)
NEXT_PUBLIC_SUPABASE_URL=https://insyznbfjequsgcuvnwh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Prefer service_role for server API routes (Dashboard → Settings → API)
SUPABASE_SERVICE_ROLE_KEY=

# Pinata IPFS (server JWT — never NEXT_PUBLIC_)
PINATA_JWT=
# Optional dedicated gateway host (defaults to gateway.pinata.cloud)
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs
# Platform logo on IPFS (used as token fallback)
NEXT_PUBLIC_PLATFORM_LOGO_IPFS=https://gateway.pinata.cloud/ipfs/bafkreie73645vsd7clvgpqb2xh6wiko42obio4caivcjdconantwkxczou
